+/* ========================================================================
+ * FLUX LoRA Application
+ * ======================================================================== */
+
+typedef struct {
+    float *f32;
+    uint16_t *bf16;
+    int rows;
+    int cols;
+} lora_matrix_part_t;
+
+typedef struct {
+    char name[128];
+    lora_matrix_part_t parts[3];
+    int num_parts;
+} lora_target_slot_t;
+
+typedef struct {
+    char target[256];
+    const safetensor_t *a;
+    const safetensor_t *b;
+    const safetensor_t *alpha;
+} lora_pair_t;
+
+static inline float lora_bf16_to_f32(uint16_t bf16) {
+    uint32_t bits = ((uint32_t)bf16) << 16;
+    float out;
+    memcpy(&out, &bits, sizeof(out));
+    return out;
+}
+
+static inline uint16_t lora_f32_to_bf16(float value) {
+    uint32_t bits;
+    memcpy(&bits, &value, sizeof(bits));
+    uint32_t lsb = (bits >> 16) & 1u;
+    uint32_t rounding_bias = 0x7FFFu + lsb;
+    return (uint16_t)((bits + rounding_bias) >> 16);
+}
+
+static int ends_with(const char *s, const char *suffix) {
+    size_t slen = strlen(s);
+    size_t suffix_len = strlen(suffix);
+    if (suffix_len > slen) return 0;
+    return strcmp(s + slen - suffix_len, suffix) == 0;
+}
+
+static void set_lora_error(char *errbuf, size_t errbuf_size, const char *fmt, ...) {
+    if (!errbuf || errbuf_size == 0) return;
+
+    va_list args;
+    va_start(args, fmt);
+    vsnprintf(errbuf, errbuf_size, fmt, args);
+    va_end(args);
+}
+
+static float read_lora_scalar(const safetensors_file_t *sf, const safetensor_t *tensor, float default_value) {
+    if (!sf || !tensor || safetensor_numel(tensor) < 1) {
+        return default_value;
+    }
+
+    const void *data = safetensors_data(sf, tensor);
+    if (!data) {
+        return default_value;
+    }
+
+    switch (tensor->dtype) {
+        case DTYPE_F32:
+            return ((const float *)data)[0];
+        case DTYPE_F16: {
+            const uint16_t raw = ((const uint16_t *)data)[0];
+            /* Reuse the existing f16 conversion path via a temporary tensor load. */
+            float *tmp = safetensors_get_f32(sf, tensor);
+            if (!tmp) return default_value;
+            float value = tmp[0];
+            free(tmp);
+            (void)raw;
+            return value;
+        }
+        case DTYPE_BF16:
+            return lora_bf16_to_f32(((const uint16_t *)data)[0]);
+        case DTYPE_I32:
+            return (float)((const int32_t *)data)[0];
+        case DTYPE_I64:
+            return (float)((const int64_t *)data)[0];
+        default:
+            return default_value;
+    }
+}
+
+static int normalize_lora_key(const char *key, char *out, size_t out_size) {
+    const char *normalized = key;
+    if (!strncmp(normalized, "transformer.", 12)) {
+        normalized += 12;
+    }
+
+    static const struct {
+        const char *suffix;
+        const char *normalized_suffix;
+    } suffixes[] = {
+        { ".lora_A.weight", "" },
+        { ".lora_B.weight", "" },
+        { ".lora_down.weight", "" },
+        { ".lora_up.weight", "" },
+        { ".alpha", "" },
+    };
+
+    for (size_t i = 0; i < sizeof(suffixes) / sizeof(suffixes[0]); i++) {
+        if (ends_with(normalized, suffixes[i].suffix)) {
+            size_t len = strlen(normalized) - strlen(suffixes[i].suffix);
+            if (len + 1 > out_size) return 0;
+            memcpy(out, normalized, len);
+            out[len] = '\0';
+            return 1;
+        }
+    }
+
+    if (strstr(normalized, "lora") || strstr(normalized, "adapter")) {
+        if (out_size > 0) out[0] = '\0';
+        return -1;
+    }
+
+    if (out_size > 0) out[0] = '\0';
+    return 0;
+}
+
+static lora_pair_t *find_or_add_lora_pair(lora_pair_t *pairs, int *count, const char *target) {
+    for (int i = 0; i < *count; i++) {
+        if (strcmp(pairs[i].target, target) == 0) {
+            return &pairs[i];
+        }
+    }
+
+    if (*count >= SAFETENSORS_MAX_TENSORS) {
+        return NULL;
+    }
+
+    lora_pair_t *pair = &pairs[*count];
+    memset(pair, 0, sizeof(*pair));
+    strncpy(pair->target, target, sizeof(pair->target) - 1);
+    (*count)++;
+    return pair;
+}
+
+static int add_lora_target_slot(lora_target_slot_t *slots, int *count, int max_slots, const char *name,
+                                float *f32, uint16_t *bf16, int rows, int cols) {
+    if (*count >= max_slots) return 0;
+    strncpy(slots[*count].name, name, sizeof(slots[*count].name) - 1);
+    slots[*count].name[sizeof(slots[*count].name) - 1] = '\0';
+    slots[*count].parts[0].f32 = f32;
+    slots[*count].parts[0].bf16 = bf16;
+    slots[*count].parts[0].rows = rows;
+    slots[*count].parts[0].cols = cols;
+    slots[*count].num_parts = 1;
+    (*count)++;
+    return 1;
+}
+
+static int add_lora_target_slot_split(lora_target_slot_t *slots, int *count, int max_slots, const char *name,
+                                      float *f32_a, uint16_t *bf16_a, int rows_a,
+                                      float *f32_b, uint16_t *bf16_b, int rows_b,
+                                      int cols) {
+    if (*count >= max_slots) return 0;
+    strncpy(slots[*count].name, name, sizeof(slots[*count].name) - 1);
+    slots[*count].name[sizeof(slots[*count].name) - 1] = '\0';
+    slots[*count].parts[0].f32 = f32_a;
+    slots[*count].parts[0].bf16 = bf16_a;
+    slots[*count].parts[0].rows = rows_a;
+    slots[*count].parts[0].cols = cols;
+    slots[*count].parts[1].f32 = f32_b;
+    slots[*count].parts[1].bf16 = bf16_b;
+    slots[*count].parts[1].rows = rows_b;
+    slots[*count].parts[1].cols = cols;
+    slots[*count].num_parts = 2;
+    (*count)++;
+    return 1;
+}
+
+static int add_lora_target_slot_split3(lora_target_slot_t *slots, int *count, int max_slots, const char *name,
+                                       float *f32_a, uint16_t *bf16_a, int rows_a,
+                                       float *f32_b, uint16_t *bf16_b, int rows_b,
+                                       float *f32_c, uint16_t *bf16_c, int rows_c,
+                                       int cols) {
+    if (*count >= max_slots) return 0;
