+                              tf->time_embed.fc2_weight, NULL,
+                              h, h)) return 0;
+    if (!add_lora_target_slot(slots, &count, max_slots, "base_model.model.double_stream_modulation_img.lin",
+                              tf->adaln_double_img_weight, tf->adaln_double_img_weight_bf16,
