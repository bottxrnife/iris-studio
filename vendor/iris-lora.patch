+    if (!add_lora_target_slot(slots, &count, max_slots, "single_stream_modulation.linear.weight",
+                              tf->adaln_single_weight, tf->adaln_single_weight_bf16,
+                              h * 3, h)) return 0;
+    if (!add_lora_target_slot(slots, &count, max_slots, "proj_out.weight",
+                              tf->final_proj_weight, tf->final_proj_weight_bf16,
+                              tf->latent_channels, h)) return 0;
+    if (!add_lora_target_slot(slots, &count, max_slots, "base_model.model.img_in",
