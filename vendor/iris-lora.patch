+    if (!add_lora_target_slot(slots, &count, max_slots, "base_model.model.double_stream_modulation_txt.lin",
+                              tf->adaln_double_txt_weight, tf->adaln_double_txt_weight_bf16,
+                              h * 6, h)) return 0;
+    if (!add_lora_target_slot(slots, &count, max_slots, "base_model.model.single_stream_modulation.lin",
+                              tf->adaln_single_weight, tf->adaln_single_weight_bf16,
