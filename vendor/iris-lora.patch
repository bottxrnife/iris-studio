+
+static void apply_lora_delta_to_part(const float *a_f32, const float *b_f32, int rank,
+                                     float alpha_scale, lora_matrix_part_t *part, int row_offset) {
+    for (int row = 0; row < part->rows; row++) {
+        int global_row = row_offset + row;
+        for (int col = 0; col < part->cols; col++) {
+            float sum = 0.0f;
+            for (int k = 0; k < rank; k++) {
+                sum += b_f32[global_row * rank + k] * a_f32[k * part->cols + col];
+            }
+
+            float delta = sum * alpha_scale;
+            if (part->f32) {
+                part->f32[row * part->cols + col] += delta;
+            }
+            if (part->bf16) {
+                size_t idx = (size_t)row * part->cols + col;
+                float value = lora_bf16_to_f32(part->bf16[idx]) + delta;
+                part->bf16[idx] = lora_f32_to_bf16(value);
+            }
+        }
+    }
+}
+
+static int apply_lora_pair_to_slot(safetensors_file_t *sf,
+                                   const lora_pair_t *pair,
+                                   lora_target_slot_t *slot,
+                                   float lora_scale,
+                                   char *errbuf,
+                                   size_t errbuf_size) {
+    if (!pair->a || !pair->b) {
+        set_lora_error(errbuf, errbuf_size, "LoRA tensor pair incomplete for %s", pair->target);
+        return 0;
+    }
+
+    if (!((pair->a->dtype == DTYPE_BF16 || pair->a->dtype == DTYPE_F16 || pair->a->dtype == DTYPE_F32) &&
+          (pair->b->dtype == DTYPE_BF16 || pair->b->dtype == DTYPE_F16 || pair->b->dtype == DTYPE_F32))) {
+        set_lora_error(errbuf, errbuf_size, "LoRA %s must use floating-point tensors", pair->target);
+        return 0;
+    }
+    if (pair->a->ndim != 2 || pair->b->ndim != 2) {
+        set_lora_error(errbuf, errbuf_size, "LoRA %s must use rank-2 tensors", pair->target);
+        return 0;
+    }
+
+    int64_t rank = pair->a->shape[0];
+    int64_t cols = pair->a->shape[1];
+    int64_t rows = pair->b->shape[0];
+    int64_t b_rank = pair->b->shape[1];
+    int target_rows = 0;
+    int target_cols = 0;
+    for (int i = 0; i < slot->num_parts; i++) {
+        target_rows += slot->parts[i].rows;
+        target_cols = slot->parts[i].cols;
+        if (!slot->parts[i].f32 && !slot->parts[i].bf16) {
+            set_lora_error(errbuf, errbuf_size, "LoRA target %s has no writable weights", pair->target);
+            return 0;
+        }
+    }
+
+    if (rank <= 0 || b_rank != rank) {
+        set_lora_error(errbuf, errbuf_size, "LoRA rank mismatch for %s", pair->target);
+        return 0;
+    }
+    if (cols != target_cols || rows != target_rows) {
+        set_lora_error(
+            errbuf,
+            errbuf_size,
+            "LoRA shape mismatch for %s (expected [%d,%d], got [%lld,%lld])",
+            pair->target,
+            target_rows,
+            target_cols,
+            (long long)rows,
+            (long long)cols
+        );
+        return 0;
+    }
+
+    float *a_f32 = safetensors_get_f32(sf, pair->a);
+    float *b_f32 = safetensors_get_f32(sf, pair->b);
+    if (!a_f32 || !b_f32) {
+        free(a_f32);
+        free(b_f32);
+        set_lora_error(errbuf, errbuf_size, "Failed to read LoRA tensor data for %s", pair->target);
+        return 0;
+    }
+
+    float alpha = pair->alpha ? read_lora_scalar(sf, pair->alpha, (float)rank) : (float)rank;
+    float alpha_scale = (alpha / (float)rank) * lora_scale;
+
+    int row_offset = 0;
+    for (int i = 0; i < slot->num_parts; i++) {
+        apply_lora_delta_to_part(a_f32, b_f32, (int)rank, alpha_scale, &slot->parts[i], row_offset);
+        row_offset += slot->parts[i].rows;
+    }
+
+    free(a_f32);
+    free(b_f32);
+    return 1;
+}
+
+int iris_transformer_apply_lora_flux(iris_transformer_flux_t *tf,
+                                     const char *lora_path,
+                                     float lora_scale,
+                                     char *errbuf,
+                                     size_t errbuf_size) {
+    if (!tf || !lora_path || !lora_path[0]) {
+        set_lora_error(errbuf, errbuf_size, "Missing LoRA path");
+        return 0;
+    }
+    if (tf->use_mmap) {
+        set_lora_error(errbuf, errbuf_size, "LoRA application requires non-mmap transformer weights");
+        return 0;
+    }
+
+    safetensors_file_t *sf = safetensors_open(lora_path);
+    if (!sf) {
+        set_lora_error(errbuf, errbuf_size, "Failed to open LoRA file");
+        return 0;
+    }
+
+    lora_pair_t pairs[SAFETENSORS_MAX_TENSORS];
+    int pair_count = 0;
+    int saw_runtime_tensor = 0;
+
+    for (int i = 0; i < sf->num_tensors; i++) {
+        const safetensor_t *tensor = &sf->tensors[i];
+        char target[256];
+        int normalized = normalize_lora_key(tensor->name, target, sizeof(target));
+        if (normalized == 0) {
+            continue;
+        }
+        if (normalized < 0) {
+            safetensors_close(sf);
+            set_lora_error(errbuf, errbuf_size, "Unsupported LoRA tensor key: %s", tensor->name);
+            return 0;
+        }
+
+        saw_runtime_tensor = 1;
+        lora_pair_t *pair = find_or_add_lora_pair(pairs, &pair_count, target);
+        if (!pair) {
+            safetensors_close(sf);
+            set_lora_error(errbuf, errbuf_size, "Too many LoRA tensors");
+            return 0;
+        }
+
+        if (ends_with(tensor->name, ".lora_A.weight") || ends_with(tensor->name, ".lora_down.weight")) {
+            pair->a = tensor;
+        } else if (ends_with(tensor->name, ".lora_B.weight") || ends_with(tensor->name, ".lora_up.weight")) {
+            pair->b = tensor;
+        } else if (ends_with(tensor->name, ".alpha")) {
+            pair->alpha = tensor;
+        }
+    }
+
+    if (!saw_runtime_tensor || pair_count == 0) {
+        safetensors_close(sf);
+        set_lora_error(errbuf, errbuf_size, "The file does not contain supported FLUX LoRA tensors");
+        return 0;
+    }
+
+    int max_slots = 16 + (tf->num_double_layers * 16) + (tf->num_single_layers * 4);
+    if (max_slots < 16) max_slots = 16;
+
+    lora_target_slot_t *slots = calloc((size_t)max_slots, sizeof(lora_target_slot_t));
+    if (!slots) {
+        safetensors_close(sf);
+        set_lora_error(errbuf, errbuf_size, "Failed to allocate FLUX LoRA target map");
+        return 0;
+    }
+
+    int slot_count = build_lora_target_slots(tf, slots, max_slots);
+    if (slot_count <= 0) {
+        free(slots);
+        safetensors_close(sf);
+        set_lora_error(errbuf, errbuf_size, "Failed to build FLUX LoRA target map");
+        return 0;
+    }
+
+    for (int i = 0; i < pair_count; i++) {
+        lora_target_slot_t *slot = find_lora_target_slot(slots, slot_count, pairs[i].target);
+        if (!slot) {
+            free(slots);
+            safetensors_close(sf);
+            set_lora_error(errbuf, errbuf_size, "Unsupported FLUX LoRA target: %s", pairs[i].target);
+            return 0;
+        }
+        if (!apply_lora_pair_to_slot(sf, &pairs[i], slot, lora_scale, errbuf, errbuf_size)) {
+            free(slots);
+            safetensors_close(sf);
+            return 0;
+        }
+    }
+
+    free(slots);
+
+#ifdef USE_METAL
+    if (tf->use_bf16) {
+        iris_metal_clear_weight_cache_only();
+        iris_metal_clear_bf16_cache_only();
+        iris_metal_clear_f16_cache_only();
+    }
+#endif
+
+    if (iris_verbose) {
+        fprintf(stderr, "Applied FLUX LoRA: %s (scale %.3f)\n", lora_path, lora_scale);
+    }
+
+    safetensors_close(sf);
+    return 1;
+}
