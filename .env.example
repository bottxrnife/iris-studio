# All paths are absolute. Adjust to match your machine.
# The quickstart.sh script generates this file automatically.
IRIS_BIN=/Users/yourname/irisapp/vendor/iris.c/iris
IRIS_MODEL_DIR=/Users/yourname/irisapp/Models
IRIS_LORA_DIR=/Users/yourname/irisapp/Loras
IRIS_OUTPUT_DIR=/Users/yourname/irisapp/Outputs
IRIS_UPLOAD_DIR=/Users/yourname/irisapp/storage/uploads
IRIS_THUMB_DIR=/Users/yourname/irisapp/storage/thumbs
IRIS_DB_PATH=/Users/yourname/irisapp/storage/app.db
